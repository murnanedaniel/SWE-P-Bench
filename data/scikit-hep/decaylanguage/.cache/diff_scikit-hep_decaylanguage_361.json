"diff --git a/tests/data/models/model-BaryonPCR.dec b/tests/data/models/model-BaryonPCR.dec\nnew file mode 100644\nindex 00000000..3740d5be\n--- /dev/null\n+++ b/tests/data/models/model-BaryonPCR.dec\n@@ -0,0 +1,7 @@\n+# File for testing purposes. Contains a single decay mode with a specific model.\n+\n+Decay Lambda_b0\n+  1.  Lambda_c+  mu-  anti-nu_mu  BaryonPCR  1 1 1 1;\n+Enddecay\n+\n+End\ndiff --git a/tests/data/models/model-GOITY_ROBERTS.dec b/tests/data/models/model-GOITY_ROBERTS.dec\nnew file mode 100644\nindex 00000000..5c5a934f\n--- /dev/null\n+++ b/tests/data/models/model-GOITY_ROBERTS.dec\n@@ -0,0 +1,7 @@\n+# File for testing purposes. Contains a single decay mode with a specific model.\n+\n+Decay B0\n+  0.0015   D-   pi0   mu+   nu_mu   PHOTOS   GOITY_ROBERTS;\n+Enddecay\n+\n+End\ndiff --git a/tests/data/models/model-LNUGAMMA.dec b/tests/data/models/model-LNUGAMMA.dec\nnew file mode 100644\nindex 00000000..69e0faa6\n--- /dev/null\n+++ b/tests/data/models/model-LNUGAMMA.dec\n@@ -0,0 +1,8 @@\n+# File for testing purposes. Contains a single decay mode with a specific model.\n+# Example taken from the example files in the EvtGen repository https://gitlab.cern.ch/evtgen/evtgen.\n+\n+Decay B+\n+1.0  e+  nu_e  gamma  LNUGAMMA  0.35  3.0  5.0  0;\n+Enddecay\n+\n+End\ndiff --git a/tests/data/models/model-PHSP.dec b/tests/data/models/model-PHSP.dec\nnew file mode 100644\nindex 00000000..53ccde6b\n--- /dev/null\n+++ b/tests/data/models/model-PHSP.dec\n@@ -0,0 +1,7 @@\n+# File for testing purposes. Contains a single decay mode with a specific model.\n+\n+Decay X\n+  1.  A  B PHOTOS PHSP;\n+Enddecay\n+\n+End\ndiff --git a/tests/data/models/model-SSD_CP.dec b/tests/data/models/model-SSD_CP.dec\nnew file mode 100644\nindex 00000000..a288c59b\n--- /dev/null\n+++ b/tests/data/models/model-SSD_CP.dec\n@@ -0,0 +1,10 @@\n+# File for testing purposes. Contains a single decay mode with a specific model.\n+\n+Define dm 0.507e12\n+Define minusTwoBeta -0.78\n+\n+Decay B0\n+0.0