"diff --git a/.ci/azure-steps.yml b/.ci/azure-steps.yml\nnew file mode 100644\nindex 00000000..1bcea8dd\n--- /dev/null\n+++ b/.ci/azure-steps.yml\n@@ -0,0 +1,36 @@\n+steps:\n+- task: UsePythonVersion@0\n+  inputs:\n+    versionSpec: '$(python.version)'\n+    architecture: 'x64'\n+\n+- script: |\n+    python -m pip install --upgrade pip\n+    python -m pip install --upgrade pytest\n+    python -m pip install pytest-cov\n+  displayName: 'Install dependencies'\n+\n+- script: |\n+    python -m pip install numpy pandas\n+  displayName: 'Install Pandas'\n+  condition: and(succeeded(), ne(variables['python.version'], '2.7'))\n+\n+- script: |\n+    python -m pip install -e .\n+  displayName: 'Install package'\n+\n+- script: |\n+    python -m pytest tests --doctest-modules --junitxml=junit/test-results.xml --cov=particle --cov-report=xml --cov-report=html\n+  displayName: 'Test with pytest and collect coverage metrics'\n+\n+- task: PublishTestResults@2\n+  inputs:\n+    testResultsFiles: '**/test-*.xml'\n+    testRunTitle: 'Publish test results for Python $(python.version)'\n+  condition: succeededOrFailed()\n+\n+- task: PublishCodeCoverageResults@1\n+  inputs:\n+    codeCoverageTool: Cobertura\n+    summaryFileLocation: '$(System.DefaultWorkingDirectory)/**/coverage.xml'\n+    reportDirectory: '$(System.DefaultWorkingDirectory)/**/htmlcov'\ndiff --git a/azure-pipelines.yml b/azure-pipelines.yml\nindex 1df0b705..31de283c 100644\n--- a/azure-pipelines.yml\n+++ b/azure-pipelines.yml\n@@ -8,59 +8,45 @@ trigger:\n \n jobs:\n \n-- job: 'Test'\n-\n+- job: 'Linux'\n   pool:\n-    vmImage: $(imageName)\n-\n+    vmImage: 'ubuntu-16.04'\n   strategy:\n     matrix:\n-      Python27-Linux:\n-        imageName: 'ubuntu-16.04'\n-        python.version: '2.7'\n-      Python27-Win:\n-        imageName: 'vs2017-win2016'\n+      Python27:\n         python.version: '2.7'\n-      Python35-Linux:\n-        imageName: 'ubuntu-16.04'\n+      Python35:\n         python.version: '3.5'\n-      Python