"diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml\nnew file mode 100644\nindex 0000000000..1765341375\n--- /dev/null\n+++ b/.github/workflows/ci.yml\n@@ -0,0 +1,72 @@\n+name: CI/CD\n+\n+on:\n+  push:\n+  pull_request:\n+  # Run daily at 0:01 UTC\n+  schedule:\n+  - cron:  '1 0 * * *'\n+\n+jobs:\n+  test:\n+\n+    strategy:\n+      matrix:\n+        platform: [ubuntu-latest]\n+        python-version: [3.6, 3.7]\n+    runs-on: ${{ matrix.platform }}\n+\n+    steps:\n+    - uses: actions/checkout@master\n+    - name: Set up Python ${{ matrix.python-version }}\n+      uses: actions/setup-python@v1\n+      with:\n+        version: ${{ matrix.python-version }}\n+    - name: Install dependencies\n+      run: |\n+        python -m pip install --upgrade pip setuptools wheel\n+        pip install --ignore-installed -U -q --no-cache-dir -e .[complete]\n+        pip list\n+    - name: Lint with Pyflakes\n+      run: |\n+        pyflakes src\n+        check-manifest\n+    - name: Lint with Black\n+      run: |\n+        black --check --diff --verbose .\n+    - name: Check MANIFEST\n+      run: |\n+        check-manifest\n+    - name: Test with pytest\n+      run: |\n+        python -m pytest -r sx --ignore tests/benchmarks/\n+    - name: Run benchmarks\n+      if: github.event_name == 'schedule' && matrix.python-version == 3.7\n+      run: |\n+        python -m pytest -r sx tests/benchmarks/test_benchmark.py\n+\n+  docs:\n+\n+    runs-on: ubuntu-latest\n+    strategy:\n+      matrix:\n+        python-version: [3.7]\n+\n+    steps:\n+    - uses: actions/checkout@master\n+    - name: Set up Python 3.7\n+      uses: actions/setup-python@v1\n+      with:\n+        version: ${{ matrix.python-version }}\n+    - name: Install dependencies\n+      run: |\n+        python -m pip install --upgrade pip setuptools wheel\n+        pip install --ignore-installed -U -q --no-cache-dir -e .[develop]\n+        pip list\n+        sudo apt-get update\n+        sudo apt-get -qq install pandoc\n+    - name: Test and build docs\n+      run: |\n+        python -m doctest README.md\n+        cd docs && make html && cd -\n+        touch docs/_build/html/.nojekyll\n"