 leaf name is `\"el\"`), which I guess is legal, so the regex has to allow for that.\r\n\r\nThis CI is going to fail until I fix scikit-hep/awkward-1.0#416, which @tamasgal pointed out in another issue.", "created_at": "2020-08-25T14:46:38Z", "updated_at": "2020-08-26T06:21:50Z", "closed_at": "2020-08-25T14:55:38Z", "merged_at": "2020-08-25T14:55:38Z", "merge_commit_sha": "3827f967da9c1031c8b5de14a877184d1089470d", "assignees": [], "requested_reviewers": [], "requested_teams": [], "labels": [], "milestone": null, "draft": false, "commits_url": "https://api.github.com/repos/scikit-hep/uproot5/pulls/77/commits", "review_comments_url": "https://api.github.com/repos/scikit-hep/uproot5/pulls/77/comments", "review_comment_url": "https://api.github.com/repos/scikit-hep/uproot5/pulls/comments{/number}", "comments_url": "https://api.github.com/repos/scikit-hep/uproot5/issues/77/comments", "statuses_url": "https://api.github.com/repos/scikit-hep/uproot5/statuses/a6c5b598608957ecba7ea5cbc7c949349923e0f6", "head": {"label": "scikit-hep:jpivarski/tweak-regex-for-issue-74", "ref": "jpivarski/tweak-regex-for-issue-74", "sha": "a6c5b598608957ecba7ea5cbc7c949349923e0f6", "user": {"login": "scikit-hep", "id": 23454624, "node_id": "MDEyOk9yZ2FuaXphdGlvbjIzNDU0NjI0", "avatar_url": "https://avatars.githubusercontent.com/u/23454624?v=4", "gravatar_id": "", "url": "https://api.github.com/users/scikit-hep", "html_url": "https://github.com/scikit-hep", "followers_url": "https://api.github.com/users/scikit-hep/followers", "following_url": "https://api.github.com/users/scikit-hep/following{/other_user}", "gists_url": "https://api.github.com/users/scikit-hep/gists{/gist_id}", "starred_url": "https://api.github.com/users/scikit-hep/starred{/owner}{/repo}", "subscriptions_url": "https://api.github.com/users/scikit-hep/subscriptions", "organizations_url": "https://api.github.com/users/scikit-hep/orgs", "repos_url": "https://api.github.com/users/scikit-hep/repos", "events_url": "https://api.github