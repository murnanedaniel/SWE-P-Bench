_typo(self):\n         Minuit(func4, printlevel=0)\n         #self.assertRaises(RuntimeError,Minuit,func4,printlevel=0)\n \n+\n+    def test_non_invertible(self):\n+        #making sure it doesn't crash\n+        def f(x,y):\n+            return (x*y)**2\n+        m = Minuit(f,pedantic=False, print_level=0)\n+        result = m.migrad()\n+        m.hesse()\n+        try:\n+            m.matrix()\n+        except RuntimeError as e:\n+            pass\n+\n+\n     def test_fix_param(self):\n-        m = Minuit(func4,print_level=0)\n+        m = Minuit(func4,print_level=0, pedantic=False)\n         m.migrad()\n         m.minos()\n         val = m.values\n@@ -80,7 +94,7 @@ def test_fix_param(self):\n         # self.assertAlmostEqual(err['z'],4.)\n \n         #now fix z = 10\n-        m = Minuit(func4,print_level=-1,y=10.,fix_y=True)\n+        m = Minuit(func4,print_level=-1,y=10.,fix_y=True, pedantic=False)\n         m.migrad()\n         val = m.values\n         assert_almost_equal(val['x'],2.)\n@@ -97,7 +111,8 @@ def test_fix_param(self):\n \n \n     def test_fitarg(self):\n-        m = Minuit(func4,print_level=-1,y=10.,fix_y=True,limit_x=(0,20.))\n+        m = Minuit(func4,print_level=-1,y=10.,fix_y=True,limit_x=(0,20.),\n+            pedantic=False)\n         fitarg = m.fitarg\n         assert_almost_equal(fitarg['y'],10.)\n         assert_true(fitarg['fix_y'])\n@@ -121,7 +136,7 @@ def test_fitarg(self):\n class TestErrorMatrix(TestCase):\n \n     def setUp(self):\n-        self.m = Minuit(func3,print_level=0)\n+        self.m = Minuit(func3,print_level=0, pedantic=False)\n         self.m.migrad()\n \n \n@@ -138,4 +153,4 @@ def test_error_matrix_correlation(self):\n \n \n if __name__ == '__main__':\n-    unittest.main()   \n\\ No newline at end of file\n+    unittest.main()\ndiff --git a/iminuit/test/testutil.py b/iminuit/test/testutil.py\nindex 28bdeb57d..853d89b9c 100644\n--- a/iminuit/test/testutil.py\n+++ b/iminuit/test/testutil.py\n@@ -84,5 +84,15 @@ def test_rem