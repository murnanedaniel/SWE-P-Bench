"If you want speed with minimal code change this is the way to do it. This is a quick way to use cython. For a hard core cython see hard-core-tutorial.ipynb.\"\n      ]\n     },\n     {\n@@ -937,15 +937,18 @@\n      \"input\": [\n       \"%%cython\\n\",\n       \"cimport cython\\n\",\n+      \"import numpy as np\\n\",\n+      \"cimport numpy as np #overwritten those from python with cython\\n\",\n       \"\\n\",\n-      \"@cython.binding(True)#you need this otherwise iminuit can't extract signature\\n\",\n+      \"#@cython.binding(True) this works too\\n\",\n+      \"@cython.embedsignature(True)#dump signature in pydoc so describe can extract signature\\n\",\n       \"def cython_f(double x,double y,double z):\\n\",\n       \"    return (x-1.)**2 + (y-2.)**2 + (z-3.)**2 -1.\"\n      ],\n      \"language\": \"python\",\n      \"metadata\": {},\n      \"outputs\": [],\n-     \"prompt_number\": 17\n+     \"prompt_number\": 22\n     },\n     {\n      \"cell_type\": \"code\",\n@@ -961,11 +964,11 @@\n        \"output_type\": \"stream\",\n        \"stream\": \"stdout\",\n        \"text\": [\n-        \"('x', 'y', 'z')\\n\"\n+        \"['x', 'y', 'z']\\n\"\n        ]\n       }\n      ],\n-     \"prompt_number\": 18\n+     \"prompt_number\": 23\n     },\n     {\n      \"cell_type\": \"code\",\n@@ -1117,7 +1120,7 @@\n        ]\n       }\n      ],\n-     \"prompt_number\": 19\n+     \"prompt_number\": 24\n     },\n     {\n      \"cell_type\": \"markdown\",\n@@ -1144,7 +1147,7 @@\n      \"language\": \"python\",\n      \"metadata\": {},\n      \"outputs\": [],\n-     \"prompt_number\": 20\n+     \"prompt_number\": 25\n     },\n     {\n      \"cell_type\": \"code\",\n@@ -1158,13 +1161,13 @@\n      \"outputs\": [\n       {\n        \"output_type\": \"pyout\",\n-       \"prompt_number\": 21,\n+       \"prompt_number\": 26,\n        \"text\": [\n-        \"('m', 'c')\"\n+        \"['m', 'c']\"\n        ]\n       }\n      ],\n-     \"prompt_number\": 21\n+     \"prompt_number\": 26\n