"diff --git a/src/hist/axestuple.py b/src/hist/axestuple.py\nnew file mode 100644\nindex 00000000..c3745a53\n--- /dev/null\n+++ b/src/hist/axestuple.py\n@@ -0,0 +1,46 @@\n+# -*- coding: utf-8 -*-\n+from boost_histogram._internal.axistuple import (\n+    AxesTuple,\n+)  # Update to nicer location when one exists\n+\n+from typing import Any, Union, Tuple\n+\n+\n+class NamedAxesTuple(AxesTuple):\n+    __slots__ = ()\n+\n+    def _get_index_by_name(self, name: Union[int, str, None]) -> Union[int, None]:\n+        if isinstance(name, str):\n+            for i, ax in enumerate(self):\n+                if ax.name == name:\n+                    return i\n+            raise KeyError(f\"{name} not found in axes\")\n+        else:\n+            return name\n+\n+    def __getitem__(self, item: Any) -> Any:\n+        if isinstance(item, slice):\n+            item = slice(\n+                self._get_index_by_name(item.start),\n+                self._get_index_by_name(item.stop),\n+                self._get_index_by_name(item.step),\n+            )\n+        else:\n+            item = self._get_index_by_name(item)\n+\n+        return super().__getitem__(item)\n+\n+    @property\n+    def name(self) -> Tuple[str]:\n+        \"\"\"\n+        The names of the axes. May be empty strings.\n+        \"\"\"\n+        return tuple(ax.name for ax in self)  # type: ignore\n+\n+    @property\n+    def title(self) -> Tuple[str]:\n+        \"\"\"\n+        The titles of the axes. Defaults to name if title not given, or Axis N\n+        if neither was given.\n+        \"\"\"\n+        return tuple(ax.title for ax in self)  # type: ignore\ndiff --git a/src/hist/core.py b/src/hist/core.py\nindex 670f2433..8a9252b7 100644\n--- a/src/hist/core.py\n+++ b/src/hist/core.py\n@@ -11,6 +11,7 @@\n \n import hist.utils\n from .axis import Regular\n+from .axestuple import NamedAxesTuple\n \n # typing alias\n Plot1D_RetType = Tuple[matplotlib.figure.Figure, matplotlib.axes._subplots.SubplotBase]\n@@ -69,9 +70,13 @@ def __init__(self, *args, **kwargs):\n                 if not ax.title:\n                     ax.title = f\"Axis {i}\"\n \n-    @property\n-    def names(self) -> List[str]:\n-        return [ax.name for ax in self.axes]\n+    def _generate_axes_(self) -> NamedAxesTuple:\n+        \"\"\"\n+        This is called to fill in the axes. Subclasses can override it if they need\n+        to change the axes tuple.\n+        \"\"\"\n+\n+        return NamedAxesTuple(self._axis(i) for i in range(self.ndim))\n \n     @always_normal_method\n     def Regular(self, *args, **kwargs):\ndiff --git a/src/hist/named.py b/src/hist/named.py\nindex eaa1f4b0..b0970177 100644\n--- a/src/hist/named.py\n+++ b/src/hist/named.py\n@@ -11,7 +11,7 @@ def __init__(self, *args, **kwargs):\n         \"\"\"\n \n         super().__init__(*args, **kwargs)\n-        if \"\" in self.names:\n+        if \"\" in self.axes.name:\n             raise Exception(\n                 f\"Each axes in the {self.__class__.__name__} instance should have a name\"\n             )\ndiff --git a/tests/test_general.py b/tests/test_general.py\nindex c5beb10a..8f66f10a 100644\n--- a/tests/test_general.py\n+++ b/tests/test_general.py\n@@ -670,3 +670,29 @@ def test_histogram_rebin():\n     assert len(h.axes[0]) == 100\n     assert len(h[::2j].axes[0]) == 50  # type: ignore\n     assert len(h[::10j].axes[0]) == 10  # type: ignore\n+\n+\n+def test_axestuple():\n+\n+    h = Hist(\n+        axis.Regular(20, 0, 12, name=\"A\", title=\"alpha\"),\n+        axis.Regular(10, 1, 3, name=\"B\"),\n+        axis.Regular(15, 3, 5, title=\"other\"),\n+        axis.Regular(5, 3, 2),\n+    )\n+\n+    assert h.axes.name == (\"A\", \"B\", \"\", \"\")\n+    assert h.axes.title == (\"alpha\", \"B\", \"other\", \"Axis 3\")\n+\n+    assert h.axes[0].size == 20\n+    assert h.axes[\"A\"].size == 20\n+\n+    assert h.axes[1].size == 10\n+    assert h.axes[\"B\"].size == 10\n+\n+    assert h.axes[2].size == 15\n+\n+    assert h.axes[:2].size == (20, 10)\n+    assert h.axes[\"A\":\"B\"].size == (20,)\n+    assert h.axes[:\"B\"].size == (20,)\n+    assert h.axes[\"B\":].size == (10, 15, 5)\n"